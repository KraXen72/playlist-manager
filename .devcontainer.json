{
	"name":"Fedora Sandbox",
	"image":"ghcr.io/kraxen72/fedora-toolchain-base:latest",
	"postCreateCommand":"pnpm add -g typescript npm-check-updates degit",
	"workspaceMount":"source=${localWorkspaceFolder},target=/home/vscode/workspace,type=bind,Z",
	"workspaceFolder":"/home/vscode/workspace",
	"features": {
		"ghcr.io/kraxen72/devcontainer-features/common-utils-bash-prompt:1": {},
		"ghcr.io/kraxen72/devcontainer-features/pnpm:1": {},
		"ghcr.io/kraxen72/devcontainer-features/copilot-cli:1": { "version": "latest" },
		"ghcr.io/kraxen72/devcontainer-features/ssh-zed:2": {}
	},
	"mounts": [
		"source=${localEnv:HOME}/.copilot,target=/home/vscode/.copilot,type=bind,Z"
	],
	"containerEnv":{
		"PNPM_HOME":"/home/vscode/.local/share/pnpm"
	},
	"remoteEnv":{
		"PATH":"${containerEnv:PNPM_HOME}:${containerEnv:PATH}"
	},
	"runArgs":[
		"--publish=${localEnv:DCMAN_SSH_PORT}:2222",
		"--cap-drop=ALL",
		"--cap-add=SETUID",
		"--cap-add=SETGID",
		"--security-opt=no-new-privileges",
		"--tmpfs=/tmp:exec,mode=1777",
		"--pids-limit=2048",
		"--ulimit=nproc=2048:2048",
		"--ulimit=nofile=65536:65536"
	],
	"remoteUser":"vscode",
	"updateRemoteUserUID":true,
	"customizations":{
		"vscode":{
			"settings":{
				"chat.tools.global.autoApprove": true
			}
		}
	}
}
